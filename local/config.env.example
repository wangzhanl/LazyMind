# LazyMind local mode configuration.
# make local-up copies this file to local/config.env when local/config.env
# does not exist, then includes local/config.env for both build-time and run-time
# variables. Keep this file in Makefile-compatible KEY=value syntax.

# Toolchain and runtime options
GO=go
PYTHON=python3
UV=uv
LAZYMIND_RUNTIME_PROFILE=local
LAZYMIND_PROCESS_COMPOSE_DOWN_TIMEOUT=60s
LAZYMIND_LOCAL_DOWN_TIMEOUT=150s
LAZYMIND_LOCAL_UP_TIMEOUT=30m
LAZYMIND_LOCAL_PYTHON_VERSION=3.11.15
LAZYMIND_AUTH_SERVICE_UV=uv
LAZYMIND_AUTH_SERVICE_INSTALL_DEPS=true
LAZYMIND_CADDY_VERSION=2.10.2
LAZYMIND_CADDY_BIN=

# Network profile and ports
LAZYMIND_LOCAL_PORTS_PINNED=false
LAZYMIND_LOCAL_NETWORK_PROFILE=localhost
LAZYMIND_LOCAL_AUTO_LOGIN_ALLOW_LAN=false
LAZYMIND_PROCESS_COMPOSE_PORT=19080
LAZYMIND_FRONTEND_PORT=8090
LAZYMIND_FRONTEND_LAN_ORIGIN=
LAZYMIND_LOCAL_PROXY_ADDRESS=127.0.0.1
LAZYMIND_LOCAL_PROXY_PORT=5024
LAZYMIND_LOCAL_AUTH_PORT=18000
LAZYMIND_AUTH_SERVICE_PORT=18000
LAZYMIND_LOCAL_PROXY_AUTH_HOST_PORT=18000
LAZYMIND_LOCAL_CORE_PORT=18001
LAZYMIND_LOCAL_PROXY_CORE_HOST_PORT=18001
LAZYMIND_LOCAL_DOC_PORT=18002
LAZYMIND_LOCAL_PROCESSOR_PORT=18003
LAZYMIND_LOCAL_ALGO_PORT=18004
LAZYMIND_LOCAL_WORKER_PORT=18005
LAZYMIND_LOCAL_CHAT_PORT=18046
LAZYMIND_LOCAL_PROXY_CHAT_HOST_PORT=18046
LAZYMIND_LOCAL_EVO_PORT=18047
LAZYMIND_LOCAL_PROXY_EVO_HOST_PORT=18047
LAZYMIND_LOCAL_PROXY_SCAN_HOST_PORT=18080
LAZYMIND_LOCAL_FILE_WATCHER_PORT=19090
LAZYMIND_LOCAL_POSTGRES_PORT=15432
LAZYMIND_LOCAL_MILVUS_PORT=19530
LAZYMIND_LOCAL_OPENSEARCH_PORT=19200
LAZYMIND_ROUTER_PORT_POOL_START=18100
LAZYMIND_ROUTER_PORTS_PER_INSTANCE=100
LAZYMIND_ROUTER_PORT_POOL_END=18199

# Local build and data paths
# Application artifacts stay under the repo-local build root:
#   $(CURDIR)/local/build/bin
#   $(CURDIR)/local/build/runtimes/python
#   $(CURDIR)/local/build/runtimes/node
#   $(CURDIR)/local/build/deps/python
#   $(CURDIR)/local/build/deps/node
#
# Runtime data uses platform user-data defaults unless overridden:
#   macOS:   ~/Library/Application Support/LazyMind
#   Windows: %LOCALAPPDATA%/LazyMind
#   Linux:   ${XDG_DATA_HOME:-~/.local/share}/LazyMind
# Logs and caches use platform log/cache roots. Local knowledge-base imports
# default to ~/Documents/LazyMind.
# LAZYMIND_RUNTIME_ROOT=
# LAZYMIND_LOCAL_SQLITE_DIR=
# LAZYMIND_LOCAL_MILVUS_DATA_DIR=
# LAZYMIND_FILE_WATCHER_BASE_ROOT=
# LAZYMIND_FILE_WATCHER_WATCH_HOST_DIR=
# LAZYMIND_FILE_WATCHER_HOST_PATH_STYLE=
LAZYMIND_HOST_HOME=$(HOME)

# Auth, bootstrap, and service-to-service secrets
LAZYMIND_AUTH_SERVICE_DATABASE_URL=
LAZYMIND_JWT_SECRET=dev-secret-change-me
LAZYMIND_JWT_TTL_MINUTES=60
LAZYMIND_JWT_REFRESH_TTL_DAYS=7
LAZYMIND_AUTH_CLOUD_SECRET_KEY=dev-ragscan-secret-key-change-me
LAZYMIND_AUTH_SERVICE_INTERNAL_TOKEN=dev-internal-service-token
LAZYMIND_BOOTSTRAP_ADMIN_USERNAME=admin
LAZYMIND_BOOTSTRAP_ADMIN_PASSWORD=admin
LAZYMIND_CHAT_UNLIKE_SWITCH=true

# Core service options
LAZYMIND_UPLOAD_TEXT_UTF8_CONVERT_ENABLED=true
LAZYMIND_FILE_URL_SIGN_SECRET=changeme-in-production
LAZYMIND_FILE_URL_EXPIRE_SECONDS=3600
LAZYMIND_OFFICE_CONVERT_WORKERS=4
LAZYMIND_RESOURCE_UPDATE_ENABLED=true

# File watcher and scan control plane
LAZYMIND_FILE_WATCHER_AGENT_ID=file-watcher-local-001
LAZYMIND_FILE_WATCHER_AGENT_TOKEN=my-secret-token
LAZYMIND_SCAN_CONTROL_PLANE_AGENT_TOKEN=my-secret-token
LAZYMIND_SCAN_CONTROL_PLANE_LOCAL_FS_DEFAULT_AGENT_ID=file-watcher-local-001
LAZYMIND_SCAN_CONTROL_PLANE_FEISHU_BASE_URL=https://open.feishu.cn
SOURCEENGINE_TARGET_SEARCH_CACHE_PREWARM_STAGGER=10s

# Proxies
http_proxy=
https_proxy=
HTTP_PROXY=
HTTPS_PROXY=
no_proxy=localhost,127.0.0.1,::1
NO_PROXY=localhost,127.0.0.1,::1

# Model providers and tracing
TZ=Asia/Shanghai
LAZYMIND_MAAS_API_KEY=
LAZYLLM_OPENAI_API_KEY=
LAZYLLM_OPENAI_API_BASE=
LAZYLLM_QWEN_API_KEY=
LAZYLLM_KIMI_API_KEY=
LAZYLLM_SENSECORE_API_KEY=
LAZYLLM_SENSECORE_API_BASE=
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LAZYLLM_TRACE_ENABLED=1
LAZYLLM_TRACE_BACKEND=local
OTEL_EXPORTER_OTLP_TIMEOUT=60
OTEL_EXPORTER_OTLP_TRACES_TIMEOUT=60
LAZYMIND_LANGFUSE_FORCE_FLUSH_TIMEOUT_MS=70000

# OCR and document processing
LAZYMIND_OCR_SERVER_URL=
LAZYMIND_MINERU_BACKEND=pipeline
LAZYMIND_MINERU_SERVER_PORT=8000
LAZYLLM_MINERU_BACKEND=pipeline
LAZYLLM_MINERU_API_KEY=
# MinerU online SSL verify defaults to true. Skipped when LAZYMIND_RUNTIME_MODE=local
# (set automatically by local-runtime-manager) or when explicitly set:
# LAZYLLM_MINERU_SSL_VERIFY=false
LAZYLLM_PADDLE_API_KEY=
LAZYMIND_MODEL_CONFIG_PATH=dynamic
LAZYMIND_DOCUMENT_WORKER_NUM_WORKERS=1
LAZYMIND_DOCUMENT_WORKER_LEASE_DURATION=300
LAZYMIND_DOCUMENT_WORKER_LEASE_RENEW_INTERVAL=60
LAZYMIND_DOCUMENT_WORKER_HIGH_PRIORITY_TASK_TYPES=
LAZYMIND_DOCUMENT_WORKER_HIGH_PRIORITY_ONLY=false
LAZYMIND_DOCUMENT_WORKER_POLL_MODE=direct

# Algorithm, stores, router, and evo
LAZYLLM_ALGO_REGISTER_POLICY=force
LAZYMIND_RESET_ALGO_ON_STARTUP=false
LAZYMIND_RESET_ALL_ON_STARTUP=false
LAZYMIND_OPENSEARCH_URI=https://127.0.0.1:19200
LAZYMIND_OPENSEARCH_USER=admin
LAZYMIND_OPENSEARCH_PASSWORD=LazyRAG_OpenSearch123!
LAZYMIND_SEGMENT_STORE_TYPE=SQLiteStore
LAZYMIND_SEGMENT_STORE_URI_OR_PATH=
LAZYMIND_SEGMENT_STORE_USER=admin
LAZYMIND_SEGMENT_STORE_PASSWORD=LazyRAG_OpenSearch123!
LAZYMIND_MAX_RETRIES=20
LAZYMIND_REVIEW_MAX_RETRIES=5
LAZYMIND_SKILL_REVIEW_DEBUG=false
LAZYMIND_MAX_CONCURRENCY=10
LAZYMIND_LLM_PRIORITY=0
LAZYMIND_ENABLE_ROUTER=true
LAZYMIND_ROUTER_HOST=127.0.0.1
LAZYMIND_LOCAL_ENABLE_EVO=false
LAZYMIND_EVO_CODE_TIMEOUT_S=900
LAZYMIND_EVO_LLM_ROLE=evo_llm
LAZYMIND_WORD_GROUP_APPLY_URL=
