# Mirror configuration
# ---------------------------------------------------------------------------
# Quick switch: set MIRROR_PROFILE to select a pre-built mirror profile.
#   cn   — domestic sources (Aliyun, daocloud, goproxy.cn) — DEFAULT
#   intl — international sources (Docker Hub, PyPI, golang.org)
#
# With Makefile:
#   make up MIRROR_PROFILE=intl        (one-off)
#   MIRROR_PROFILE=intl  ← add to this file for persistent switch
#
# Without Makefile (docker compose directly):
#   docker compose --env-file .env.mirrors.intl up -d
#
# Individual variables below override the selected profile when uncommented.
# ---------------------------------------------------------------------------

#MIRROR_PROFILE=intl

# Docker Hub mirror prefix (trailing slash required)
# Domestic (default): docker.m.daocloud.io/library/
# International:      (empty string — pull directly from Docker Hub)
#DOCKER_MIRROR=

# PyPI mirror
# Domestic (default): https://mirrors.aliyun.com/pypi/simple
# International:      https://pypi.org/simple
#PIP_INDEX_URL=https://pypi.org/simple

# Go module proxy
# Domestic (default): https://goproxy.cn,direct
# International:      https://proxy.golang.org,direct
#GOPROXY=https://proxy.golang.org,direct

# APT mirror (used inside Python/Go Docker images based on Debian)
# Domestic (default): http://mirrors.aliyun.com/debian
# International:      http://deb.debian.org/debian
#APT_MIRROR=http://deb.debian.org/debian
#APT_SECURITY_MIRROR=http://security.debian.org

# pip timeout / retry tuning
#PIP_DEFAULT_TIMEOUT=300
#PIP_RETRIES=10

# Model configuration
# All algorithm services use LAZYMIND_MODEL_CONFIG_PATH. The default is dynamic,
# so per-user model/API-key selections from the frontend can be injected per request.
# Set online/inner only when forcing a static config.
#LAZYMIND_MODEL_CONFIG_PATH=dynamic
#LAZYMIND_CHAT_UNLIKE_SWITCH=false
#LAZYLLM_QWEN_API_KEY=your-qwen-api-key

# ModuleCache (lazyllm ModuleBase): LAZYLLM_CACHE_STRATEGY / LAZYLLM_CACHE_MODE / LAZYLLM_CACHE_DIR
#LAZYLLM_CACHE_STRATEGY=file
#LAZYLLM_CACHE_MODE=RW
#LAZYLLM_CACHE_DIR=/var/lib/lazymind/uploads/.lazyllm_cache
#LAZYMIND_READER_USE_CACHE=true  # forwarded to LAZYLLM_READER_USE_CACHE (lazyllm.config reader_use_cache)

# File-watcher configuration
# ---------------------------------------------------------------------------
# LAZYMIND_FILE_WATCHER_BASE_ROOT: host directory used as the file-watcher
#   data root (PID file, logs, staging area). Default: ./data/scan
#LAZYMIND_FILE_WATCHER_BASE_ROOT=./data/scan

# LAZYMIND_FILE_WATCHER_WATCH_HOST_DIR: host directory the file-watcher
#   monitors for new documents. Auto-detected per OS:
#     macOS   → /Users
#     Linux   → /tmp
#     Windows → D:/
# Uncomment and set to override.
#LAZYMIND_FILE_WATCHER_WATCH_HOST_DIR=/home

# LAZYMIND_FILE_WATCHER_MODE: container (default) or host.
#   container — file-watcher runs as a Docker service (recommended)
#   host      — file-watcher runs as a host process (for local debugging)
#LAZYMIND_FILE_WATCHER_MODE=container

# Frontend feature flags
# ---------------------------------------------------------------------------
# VITE_HIDE_EVO: hide the Self-Evolution (Evo) page from the web UI.
#   Not set (default) — Evo page is visible
#   Set to any value   — Evo page is hidden
#VITE_HIDE_EVO=true
